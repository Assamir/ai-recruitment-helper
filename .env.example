# Supabase
SUPABASE_URL=###
SUPABASE_KEY=###

# Cloudflare
CLOUDFLARE_API_TOKEN=###
CLOUDFLARE_ACCOUNT_ID=###

# LLM — set LLM_PROVIDER to "lmstudio" (local, default) or "openrouter" (cloud)
OPENROUTER_API_KEY=###
LLM_PROVIDER=lmstudio
LLM_MODEL=google/gemma-4-e4b

# LinkedIn scraping (optional) — li_at cookie from a logged-in browser session.
# Set in production via: npx wrangler secret put LINKEDIN_SESSION_COOKIE
LINKEDIN_SESSION_COOKIE=###

# E2E (Playwright) — credentials for an EXISTING Supabase test user.
# Used only by tests/e2e/auth.setup.ts to sign in once. See tests/e2e/README.md.
E2E_EMAIL=###
E2E_PASSWORD=###
