{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ai-recruiter",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-05-08",
	// Free tier: 10ms CPU per invocation (sufficient for auth + page renders).
	// CV analysis pipeline (FR-006) and Browser Run (S-03 LinkedIn scraping) require the Workers Paid plan.
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
		"not_found_handling": "404-page",
	},
	"observability": {
		"enabled": true,
	},
	"browser": {
		"binding": "BROWSER",
	},
	// Playwright E2E test user (tests/e2e/README.md). Synced to Cloudflare on `wrangler deploy`.
	"vars": {
		"E2E_EMAIL": "test-user@example.com",
		"E2E_PASSWORD": "TestUser-1#",
		"LLM_PROVIDER": "openrouter",
		"LLM_MODEL": "openai/gpt-4o",
	},
}