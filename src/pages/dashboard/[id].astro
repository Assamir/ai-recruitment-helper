---
import Layout from "@/layouts/Layout.astro";

const { id } = Astro.params;
---

<Layout title="Analysis — QA Recruiter">
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-3xl">
      <div class="mb-6">
        <a href="/dashboard" class="text-sm text-blue-100/50 transition-colors hover:text-blue-100/80"> ← Dashboard </a>
      </div>
      <div
        id="analysis-root"
        data-analysis-id={id}
        class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center text-sm text-blue-100/60 backdrop-blur-xl"
      >
        Loading analysis…
      </div>
    </div>
  </div>
</Layout>
