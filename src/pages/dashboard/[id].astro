---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import AnalysisView from "@/components/analysis/AnalysisView";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);

let initialStatus = "parsing";
if (supabase) {
  const { data, error } = await supabase.from("analyses").select("status").eq("id", id).single();
  // RLS-denied and non-existent rows both come back empty — don't render a
  // fake live-progress UI for analyses the user can't see.
  // eslint-disable-next-line @typescript-eslint/no-unnecessary-condition -- generated types model single() as always-present, but RLS denial returns an empty result at runtime
  if (error || !data) {
    return Astro.redirect("/dashboard");
  }
  initialStatus = data.status;
}
---

<Layout title="Analysis — QA Recruiter">
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-3xl">
      <div class="mb-6">
        <a href="/dashboard" class="text-sm text-blue-100/50 transition-colors hover:text-blue-100/80"> ← Dashboard </a>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-xl">
        <AnalysisView analysisId={id} initialStatus={initialStatus} client:load />
      </div>
    </div>
  </div>
</Layout>
