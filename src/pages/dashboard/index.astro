---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

interface AnalysisRow {
  id: string;
  status: string;
  created_at: string;
  candidates: { file_name: string | null; first_name: string | null; last_name: string | null } | null;
  job_profiles: { name: string; seniority_level: string | null } | null;
}

const analyses: AnalysisRow[] = supabase
  ? (((
      await supabase
        .from("analyses")
        .select(
          "id, status, created_at, candidates(file_name, first_name, last_name), job_profiles(name, seniority_level)",
        )
        .order("created_at", { ascending: false })
    ).data as AnalysisRow[] | null) ?? [])
  : [];

const statusLabel: Record<string, string> = {
  parsing: "Parsing",
  anonymizing: "Anonymizing",
  analyzing: "Analyzing",
  completed: "Completed",
  failed: "Failed",
};

const statusColor: Record<string, string> = {
  parsing: "text-blue-300",
  anonymizing: "text-yellow-300",
  analyzing: "text-purple-300",
  completed: "text-green-300",
  failed: "text-red-400",
};
---

<Layout title="Dashboard — QA Recruiter">
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-4xl">
      <!-- Header -->
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            Dashboard
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">{user?.email}</p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/dashboard/new"
            class="rounded-lg border border-blue-400/30 bg-blue-500/20 px-4 py-2 text-sm font-medium text-blue-200 transition-colors hover:border-blue-400/50 hover:bg-blue-500/30"
          >
            + New Analysis
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm text-blue-100/60 transition-colors hover:bg-white/10"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>

      <!-- Analysis list -->
      {
        analyses.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-12 text-center backdrop-blur-xl">
            <div class="mb-4 text-4xl">🔍</div>
            <h2 class="mb-2 text-xl font-semibold text-white">No analyses yet</h2>
            <p class="mb-6 text-blue-100/60">Upload a QA candidate's CV to generate interview questions.</p>
            <a
              href="/dashboard/new"
              class="inline-block rounded-lg border border-blue-400/30 bg-blue-500/20 px-6 py-3 text-sm font-medium text-blue-200 transition-colors hover:bg-blue-500/30"
            >
              Start your first analysis
            </a>
          </div>
        ) : (
          <div class="space-y-3">
            {analyses.map((a) => {
              const profile = a.job_profiles;
              const candidate = a.candidates;
              const profileLabel = profile
                ? [profile.name, profile.seniority_level].filter(Boolean).join(" — ")
                : "Unknown profile";
              const displayName =
                [candidate?.first_name, candidate?.last_name].filter(Boolean).join(" ") ||
                (candidate?.file_name ?? "Pasted CV");
              const date = new Date(a.created_at).toLocaleDateString("en-GB", {
                day: "numeric",
                month: "short",
                year: "numeric",
              });
              const color = statusColor[a.status] ?? "text-white/60";
              const label = statusLabel[a.status] ?? a.status;

              return (
                <a
                  href={`/dashboard/${a.id}`}
                  class="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-5 py-4 backdrop-blur-md transition-all hover:border-white/20 hover:bg-white/10"
                >
                  <div class="min-w-0 flex-1">
                    <p class="truncate font-medium text-white">{displayName}</p>
                    <p class="mt-0.5 truncate text-sm text-blue-100/60">{profileLabel}</p>
                  </div>
                  <div class="ml-4 flex shrink-0 flex-col items-end gap-1">
                    <span class:list={`text-sm font-medium ${color}`}>{label}</span>
                    <span class="text-xs text-blue-100/40">{date}</span>
                  </div>
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </div>
</Layout>
